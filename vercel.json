{
  "version": 2,
  "builds": [
    { "src": "flask_app.py", "use": "@vercel/python" },
    { "src": "public/*.apk", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "flask_app.py" }
  ],
  "env": {
    "FORCE_REBUILD": "2026-04-10-STATIC-FIX"
  }
}
